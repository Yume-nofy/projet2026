RewriteEngine On

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /web/$1 [R=301,L]
Options -Indexes

# 3. RÈGLE POUR L'ACCUEIL
# URL : /accueil.html -> index.php
RewriteRule ^accueil\.html$ index.php [L]

# 4. RÈGLE POUR LES ARTICLES (Format Mr Rojo : article-slug-id.html)
# URL : /article-ma-guerre-en-iran-12.html -> index.php?action=article&id=12
# On capture le slug ([a-z0-9-]+) et l'ID ([0-9]+)
RewriteRule ^article-([a-z0-9-]+)-([0-9]+)\.html$ index.php?action=article&id=$2 [L,QSA]

# 5. RÈGLE POUR LES RÉGIONS (Format : region-nom-id.html)
RewriteRule ^region-([a-z0-9-]+)-([0-9]+)\.html$ index.php?action=region&id=$2 [L,QSA]

# 6. GESTION DES ERREURS
ErrorDocument 404 /projet2026-main/web/index.php

<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType application/javascript "access plus 1 month"
	ExpiresByType application/x-javascript "access plus 1 month"
	ExpiresByType image/jpeg "access plus 1 month"
	ExpiresByType image/png "access plus 1 month"
	ExpiresByType image/svg+xml "access plus 1 month"
	ExpiresByType image/gif "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
	<FilesMatch "\.(css|js|jpg|jpeg|png|svg|gif)$">
		Header set Cache-Control "public, max-age=2592000, immutable"
	</FilesMatch>
</IfModule>

# Enable gzip if available
<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

